# Telegram Bot
TG_BOT_TOKEN=your_telegram_bot_token_here
TG_ENABLED=true
TG_ADMIN_IDS=your_telegram_user_id
BOT_USERNAME=your_bot_username_here

# Agent identity and deployment
AGENT_ID=btc-whalescope-agent-prod
AGENT_NAME=BTC-WhaleScope-Agent
APP_VERSION=local-dev
DEPLOY_ENV=production
COMPOSE_PROJECT_NAME=btc-whalescope-agent
CONTAINER_NAME=btc-whalescope-agent-app

# Deepseek AI
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=1000
DEEPSEEK_TEMPERATURE=0.7

# CoinGlass API
CG_API_KEY=your_coinglass_api_key_here

# 服务配置
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# 数据库
DB_PATH=data/whale_orders.db
USER_DB_PATH=data/users.db

# 采集配置（秒）
POLL_INTERVAL_LARGE_ORDER=10
POLL_INTERVAL_LIQUIDATION=10
POLL_INTERVAL_WHALE_ALERT=10
POLL_INTERVAL_ONCHAIN=60

# 监控交易所（逗号分隔）
EXCHANGES=Binance,OKX,Bybit

# 大额订单阈值（美元）
LARGE_ORDER_THRESHOLD=500000
LIQUIDATION_THRESHOLD=100000

# Webhook 配置（逗号分隔的回调URL）
WEBHOOK_URLS=

# WebSocket 推送
WS_PUSH_ENABLED=true
WEBHOOK_PUSH_ENABLED=false

# 心跳上报（Pixel Office / Supabase）
HEARTBEAT_ENABLED=false
HEARTBEAT_URL=https://ewsrmznakzzkkcwftgjd.supabase.co/rest/v1/agents
HEARTBEAT_API_KEY=your_supabase_publishable_key
HEARTBEAT_BEARER_TOKEN=your_supabase_publishable_key
HEARTBEAT_AGENT_ID=codex-btc-whalescope-01
HEARTBEAT_NAME=BTC WhaleScope Agent
HEARTBEAT_ROLE=product
HEARTBEAT_ROLE_LABEL_ZH=BTC巨鲸情报分析师

# Tencent COS (optional for file exports)
COS_BUCKET=polymarket-ai-agent-1328550492
COS_REGION=ap-tokyo
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_BASE_URL=https://polymarket-ai-agent-1328550492.cos.ap-tokyo.myqcloud.com
